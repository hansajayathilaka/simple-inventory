{
  "name": "@simple-inventory/desktop",
  "private": true,
  "version": "0.2.0",
  "description": "Electron desktop wrapper bundling PocketBase + the React UI",
  "author": "Simple Inventory",
  "repository": "http://github.com/hansajayathilaka/simple-inventory",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "42.4.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.simpleinventory.app",
    "npmRebuild": false,
    "productName": "Simple Inventory",
    "directories": {
      "output": "out"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "../backend/pb_migrations",
        "to": "backend/pb_migrations"
      },
      {
        "from": "../backend/pb_hooks",
        "to": "backend/pb_hooks"
      },
      {
        "from": "../backend/pocketbase.exe",
        "to": "backend/pocketbase.exe"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github"
    }
  }
}
